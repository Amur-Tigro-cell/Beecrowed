#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int N;
    cin >> N;

    for (int t = 0; t < N; t++) {
        int X, Y;
        cin >> X >> Y;

        int start = min(X, Y) + 1;
        int end = max(X, Y) - 1;
        int sum = 0;

        for (int i = start; i <= end; i++) {
            if (i % 2 != 0) sum += i; // add if odd
        }

        cout << sum << endl;
    }

    return 0;
}
